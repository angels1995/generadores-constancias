# Cadena de conexión Postgres (puede ser la de Supabase: Project Settings -> Database -> Connection string)
DATABASE_URL=postgresql://postgres:andy2003@host:5432/generadores

# Puerto donde escucha la API
PORT=3000

# Dominio(s) permitidos para hacer fetch a esta API (tu frontend en Cloudflare Pages)
# Si tienes varios, sepáralos por coma: https://generador.pages.dev,https://verificador.pages.dev
ORIGIN_PERMITIDO=https://tu-proyecto.pages.dev

# URL pública del verificador, usada para construir el link dentro del QR
VERIFICADOR_URL_BASE=https://tu-proyecto.pages.dev/certificado_minsa.html
